# Artemis Eval — Environment Variables
# Copy this file to .env.local and fill in the values.

# ── Backend URLs ──────────────────────────────────────────
# BACKEND_URL overrides everything (used by Next.js rewrite proxy at build time).
# If unset, falls back to BACKEND_URL_DEV.
# BACKEND_URL=http://localhost:8124

# Per-environment backend URLs (used by lib/env.ts for config display)
BACKEND_URL_DEV=http://localhost:8124
BACKEND_URL_PROD=http://localhost:8124

# ── Server ────────────────────────────────────────────────
# Frontend port (default: 61241)
PORT=61241
