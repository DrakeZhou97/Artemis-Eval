# Artemis Eval — Environment Variables
# Copy this file to .env.local and fill in the values.

# Backend API base URL (used by Next.js rewrite proxy)
# Dev default: http://localhost:8124
BACKEND_URL_DEV=http://192.168.12.239:8124

# Production backend URL
BACKEND_URL_PROD=http://192.168.12.150:8124

# Frontend port (default: 61241)
PORT=61241
